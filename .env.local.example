# Database (use pooled URL from Railway/Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/dashboard_db"

# NextAuth
NEXTAUTH_SECRET="replace-with-32-plus-char-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Pusher (Channels)
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="ap2"
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"

# Resend (free email — get key from resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Cron job protection
CRON_SECRET="replace-with-32-plus-char-random-string"
