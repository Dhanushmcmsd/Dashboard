# ──────────────────────────────────────────────
# Database (Neon / Supabase PostgreSQL)
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ──────────────────────────────────────────────
# NextAuth — rotate NEXTAUTH_SECRET every 90 days
# Generate: openssl rand -base64 32
# ──────────────────────────────────────────────
NEXTAUTH_SECRET="your-32-char-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ──────────────────────────────────────────────
# Real-time (Vercel KV — Redis pub/sub for SSE)
# Create at: vercel.com → Storage → Create KV Database
# ──────────────────────────────────────────────
KV_URL="redis://default:password@host:port"
KV_REST_API_URL="https://your-kv-store.kv.vercel-storage.com"
KV_REST_API_TOKEN="your-kv-rest-api-token"
KV_REST_API_READ_ONLY_TOKEN="your-kv-read-only-token"

# ──────────────────────────────────────────────
# Email (Resend)
# ──────────────────────────────────────────────
RESEND_API_KEY="re_your_api_key"
# Update EMAIL_FROM after verifying your domain in Resend dashboard
# Until then, onboarding@resend.dev works for testing
EMAIL_FROM="noreply@yourdomain.com"

# ──────────────────────────────────────────────
# Cron job security
# Generate: openssl rand -base64 32
# Add the same value to Vercel project env vars
# ──────────────────────────────────────────────
CRON_SECRET="your-cron-secret-here"

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ──────────────────────────────────────────────
# Observability (optional but recommended)
# ──────────────────────────────────────────────
# SENTRY_DSN="https://xxx@ooo.ingest.sentry.io/yyy"
# NEXT_PUBLIC_POSTHOG_KEY="phc_yourkey"
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
