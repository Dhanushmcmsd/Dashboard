# ─── Database ────────────────────────────────────────────────────────────────
# Format for Neon/Supabase: postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32  — rotate every 90 days
NEXTAUTH_SECRET="your-32-char-random-secret-here"
NEXTAUTH_URL="https://your-domain.vercel.app"

# ─── Pusher (Real-time) ───────────────────────────────────────────────────────
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_SECRET="your-pusher-secret"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key"

# FROM address — MUST be a verified domain in your Resend account.
# Format: "Display Name <address@yourdomain.com>"
# For local dev/testing only, you can use: "BranchSync <onboarding@resend.dev>"
RESEND_FROM_EMAIL="BranchSync <noreply@yourdomain.com>"

# ─── App URLs ────────────────────────────────────────────────────────────────
# Used in email links — must match your deployed URL, no trailing slash
NEXTAUTH_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# ─── CRON security ────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET="your-cron-secret-here"

# ─── Observability (optional but recommended) ─────────────────────────────────
# SENTRY_DSN="https://xxx@ooo.ingest.sentry.io/yyy"
# NEXT_PUBLIC_POSTHOG_KEY="phc_yourkey"
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
