# PostgreSQL connection string
# Format for local: postgresql://postgres:password@localhost:5432/branchsync
# Format for Neon: postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/branchsync?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/branchsync"

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="pF+97TSHiWa83DPvx/J/aqJo7QVKPF3nmS98Pav7+x0="
JWT_SECRET="paste-your-32-char-random-string-here"

# Pusher — from your Pusher dashboard
NEXT_PUBLIC_PUSHER_APP_KEY="your-app-key"
PUSHER_APP_ID="your-app-id"
PUSHER_SECRET="your-secret"
NEXT_PUBLIC_PUSHER_CLUSTER="mt1"   # change to your cluster (ap2 for Asia)

# Resend — from resend.com dashboard
RESEND_API_KEY="re_xxxxxxxxx"

# Cron security — generate with: openssl rand -base64 32
CRON_SECRET="ulSp5HQg0T2FtqrqMZqmIQbjI53qGAmNcQKIswpnXs4="
