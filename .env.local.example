# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://your-domain.vercel.app"

# ─── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"

# FROM address — MUST be a verified domain in your Resend account.
# e.g. "BranchSync <noreply@yourdomain.com>"
# Without this, emails only deliver to the Resend account-owner address.
RESEND_FROM_EMAIL="BranchSync <noreply@yourdomain.com>"

# ─── CRON security ────────────────────────────────────────────────────────────
CRON_SECRET="your-cron-secret-here"
