# ──────────────────────────────────────────────────────────
# Database (Neon / Supabase PostgreSQL)
# ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ──────────────────────────────────────────────────────────
# NextAuth — rotate NEXTAUTH_SECRET every 90 days
# Generate: openssl rand -base64 32
# ──────────────────────────────────────────────────────────
NEXTAUTH_SECRET="your-32-char-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────
# Real-time (Upstash Redis — pub/sub for SSE)
# Set up at: vercel.com → Integrations → Upstash Redis
# OR: console.upstash.com → Create Database → REST API tab
#
# Used in lib/events.ts (publishEvent via @upstash/redis)
# Used in app/api/events/route.ts (SSE subscriber via redis pkg)
# ──────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# KV_URL is the raw Redis URL used by the native redis pkg in the SSE endpoint
# Format: rediss://default:password@your-db.upstash.io:6379
KV_URL="rediss://default:your-password@your-db.upstash.io:6379"

# ──────────────────────────────────────────────────────────
# Email (Resend)
# ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_your_api_key"
# Update after verifying your domain in Resend dashboard
# Until then, onboarding@resend.dev works for testing
EMAIL_FROM="noreply@yourdomain.com"

# ──────────────────────────────────────────────────────────
# Cron job security
# Generate: openssl rand -base64 32
# ──────────────────────────────────────────────────────────
CRON_SECRET="your-cron-secret-here"

# ──────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────
# Observability (optional but recommended)
# ──────────────────────────────────────────────────────────
# SENTRY_DSN="https://xxx@ooo.ingest.sentry.io/yyy"
# NEXT_PUBLIC_POSTHOG_KEY="phc_yourkey"
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
